# API backend URL (leave empty when using Vite proxy locally)
VITE_API_URL=

# Your Telegram bot username (without @), e.g. SchemaLabBot.
# В проде задаётся в Dockerfile (ENV VITE_BOT_USERNAME) и вшивается в бандл.
# Переезд на новый бот = поменять значение в Dockerfile.
VITE_BOT_USERNAME=YourBotUsername

# Короткое имя мини-аппа в deep-link t.me/<bot>/<app> (по умолчанию diary). Опционально.
VITE_MINIAPP_APP_NAME=diary
