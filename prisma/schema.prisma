generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Rating {
  id     Int    @id @default(autoincrement())
  userId Int
  date   String
  needId String
  value  Int

  @@unique([userId, date, needId])
}

model User {
  id              Int      @id
  createdAt       DateTime @default(now())
  notifyEnabled   Boolean  @default(true)
  notifyUtcHour   Int      @default(19)   // UTC hour to send notification
  notifyTzOffset  Int      @default(2)    // timezone offset in hours (for display)
}
