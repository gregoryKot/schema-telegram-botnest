generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Rating {
  id     Int    @id @default(autoincrement())
  userId BigInt
  date   String
  needId String
  value  Int

  @@unique([userId, date, needId])
}

model YsqProgress {
  userId    BigInt   @id
  answers   Json
  page      Int
  updatedAt DateTime @default(now())
}

model User {
  id                     BigInt   @id
  createdAt              DateTime @default(now())
  firstName              String?
  disclaimerAccepted     Boolean  @default(false)
  notifyEnabled          Boolean  @default(true)
  notifyUtcHour          Int      @default(19)
  notifyTzOffset         Int      @default(2)
  notifyReminderEnabled  Boolean  @default(true)
  pairCardDismissed      Boolean  @default(false)

  notifications   ScheduledNotification[]
  notes           Note[]
  pairs1          Pair[]   @relation("PairUser1")
  pairs2          Pair[]   @relation("PairUser2")
}

model Note {
  id        Int      @id @default(autoincrement())
  userId    BigInt
  date      String
  text      String
  tags      String   @default("")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Pair {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  userId1   BigInt
  userId2   BigInt?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  user1     User     @relation("PairUser1", fields: [userId1], references: [id], onDelete: Cascade)
  user2     User?    @relation("PairUser2", fields: [userId2], references: [id], onDelete: SetNull)
}

model UserPractice {
  id        Int      @id @default(autoincrement())
  userId    BigInt
  needId    String
  text      String
  createdAt DateTime @default(now())

  @@index([userId, needId])
}

model PracticePlan {
  id              Int       @id @default(autoincrement())
  userId          BigInt
  needId          String
  practiceText    String
  scheduledDate   String    // YYYY-MM-DD — дата когда планируем выполнить
  reminderUtcHour Int?      // null = без напоминания
  done            Boolean?  // null = не ответил, true/false = результат
  checkedAt       DateTime?
  createdAt       DateTime  @default(now())

  @@index([userId, scheduledDate])
}

model YsqResult {
  userId      BigInt   @id
  answers     Json
  completedAt DateTime @default(now())
}

model ChildhoodRating {
  id     Int    @id @default(autoincrement())
  userId BigInt
  needId String
  value  Int

  @@unique([userId, needId])
  @@index([userId])
}

model ScheduledNotification {
  id          Int       @id @default(autoincrement())
  userId      BigInt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sendAt      DateTime  // UTC, рассчитано заранее
  type        String    // reminder | summary | onboarding_1 | onboarding_3 | onboarding_7 | streak_7 | streak_14 | streak_30 | lapsing_2 | lapsing_4 | dormant_7 | reengagement_30 | weekly
  payload     Json?
  sentAt      DateTime?
  cancelledAt DateTime?

  @@index([sendAt, sentAt, cancelledAt])
  @@index([userId, type, sentAt])
}
