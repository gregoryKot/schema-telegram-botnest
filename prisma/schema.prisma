generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Rating {
  id     Int    @id @default(autoincrement())
  userId BigInt
  date   String
  needId String
  value  Int

  @@unique([userId, date, needId])
  @@index([userId, date])
}

model YsqProgress {
  userId    BigInt   @id
  answers   Json
  page      Int
  updatedAt DateTime @default(now())
}

enum UserRole {
  CLIENT
  THERAPIST
}

model User {
  id                     BigInt   @id
  createdAt              DateTime @default(now())
  firstName              String?
  role                   UserRole @default(CLIENT)
  disclaimerAccepted     Boolean  @default(false)
  notifyEnabled          Boolean  @default(true)
  notifyLocalHour        Int      @default(21)
  notifyTimezone         String   @default("Europe/Moscow")
  notifyReminderEnabled  Boolean  @default(true)
  // ── Adaptive notification cadence ────────────────────────────────────────
  notifyFrequency        Int      @default(0)  // выбор юзера: 0=каждый день,1=через день,2=2×/нед,3=раз/нед — потолок для адаптации
  notifyAdaptiveLevel    Int      @default(0)  // управляется движком; effective = max(frequency, adaptive)
  notifyIgnoredCount     Int      @default(0)  // подряд проигнорированных напоминаний на текущем уровне
  notifyNextRemindDate   String?               // YYYY-MM-DD (локальная дата) следующего дня напоминания
  notifySkipAckDate      String?               // YYYY-MM-DD «Сегодня не могу» — день не считается игнором
  notifyLastEvalDate     String?               // YYYY-MM-DD последнего прогона движка — идемпотентность catch-up
  notifyPausedUntil      DateTime?             // пауза уведомлений (UTC instant)
  notifyQuietStart       Int      @default(22) // тихие часы: начало, локальный час
  notifyQuietEnd         Int      @default(8)  // тихие часы: конец; start==end → выключено
  addressForm            String?               // 'ty' | 'vy'; null = ещё не выбрал → показать выбор при входе
  pairCardDismissed      Boolean  @default(false)
  mySchemaIds            Json     @default("[]")
  myModeIds              Json     @default("[]")
  therapistShareCards    Boolean  @default(true)
  therapistShareProfile  Boolean  @default(true)
  // ── Typed UI flags (migrated out of localStorage) ───────────────────────
  themePref                String?  // 'light' | 'dark' (null = system)
  onboardingV1Done         Boolean  @default(false)
  onboardingV2Done         Boolean  @default(false)
  onboardingSkipped        Json     @default("[]")  // string[] of dismissed onboarding step ids
  practicesOnboardingDone  Boolean  @default(false)
  childhoodWheelDone       Boolean  @default(false)
  ysqBannerDismissed       Boolean  @default(false)
  hintSheetCloseShown      Boolean  @default(false)
  hintHistoryDismissed     Boolean  @default(false)
  trackerOnboardingDone    Boolean  @default(false)
  lastCelebrationDate      String?  // YYYY-MM-DD — last day we showed daily celebration
  lastYesterdayBannerDate  String?  // YYYY-MM-DD — date for which "yesterday banner" was dismissed
  lastWeeklyQuestionWeek   String?  // YYYY-Www — last week the weekly question was answered/dismissed
  schemaIntrosShown        Json     @default("[]")  // string[] of schema ids whose intro was viewed
  modeIntrosShown          Json     @default("[]")  // string[] of mode ids whose intro was viewed
  therapistMode            Boolean  @default(false)
  defaultSection           String?  // last-selected bottom nav section
  botBlockedAt           DateTime?
  deletedAt              DateTime?

  notifications          ScheduledNotification[]
  notes                  Note[]
  schemaNotes            UserSchemaNote[]
  modeNotes              UserModeNote[]
  beliefChecks           UserBeliefCheck[]
  letters                UserLetter[]
  safePlace              UserSafePlace?
  flashcards             UserFlashcard[]
  pairs1                 Pair[]            @relation("PairUser1")
  pairs2                 Pair[]            @relation("PairUser2")
  therapistRelations     TherapyRelation[] @relation("TherapistOf")
  clientRelations        TherapyRelation[] @relation("ClientOf")
  ysqHistory             YsqResultHistory[]
  authProviders          AuthProvider[]
  webSessions            WebSession[]
  drafts                 DiaryDraft[]
  therapistRequest       TherapistRequest?
  // ── 2FA (TOTP, RFC 6238) ────────────────────────────────────────────────
  // totpSecret: AES-256-GCM encrypted base32 string of the TOTP shared secret.
  // totpEnabledAt: set when user confirms first valid code. null = not enabled.
  // totpRecoveryCodes: encrypted JSON array of one-time recovery hashes
  //   (sha256 hex) — used if user loses their authenticator.
  totpSecret             String?
  totpEnabledAt          DateTime?
  totpRecoveryCodes      Json     @default("[]")
  // Recovery email — last-resort path in case user loses ALL their auth
  // providers (Google/Telegram/VK all gone). Receives a magic link to add
  // a new provider. Verified separately (verifiedAt).
  recoveryEmail          String?  @unique
  recoveryEmailVerifiedAt DateTime?
}

// Email magic-link tokens — for recovery, email verification, etc.
// One-use, ~30 min TTL. Hash stored, raw token only in the email.
model EmailToken {
  id        String   @id @default(cuid())
  userId    BigInt?  // null = pre-verification (verify email before binding)
  tokenHash String   @unique
  email     String   // sent to this address
  purpose   String   // 'recovery' | 'verify_email'
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// User-initiated request to be granted THERAPIST role. Admin reviews via the
// Telegram bot (inline buttons "Approve" / "Reject"). Replaces the previous
// shared-static THERAPIST_CODE flow.
model TherapistRequest {
  id            Int       @id @default(autoincrement())
  userId        BigInt    @unique
  fullName      String
  qualification String
  contacts      String    // free text: site, telegram handle, etc
  message       String?   // optional cover letter
  status        String    @default("pending") // 'pending' | 'approved' | 'rejected'
  reviewedAt    DateTime?
  reviewedBy    BigInt?   // admin's Telegram id
  rejectReason  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

// Unsaved diary entry drafts (replaces localStorage `diary_draft_*` keys)
model DiaryDraft {
  userId    BigInt
  type      String   // 'schema' | 'mode' | 'gratitude'
  startedAt DateTime
  data      Json
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, type])
}

// OAuth provider link (telegram | google) → userId
model AuthProvider {
  id          Int      @id @default(autoincrement())
  userId      BigInt
  provider    String   // 'telegram' | 'google'
  providerId  String   // telegramId as string, or Google sub
  email       String?
  displayName String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
}

// Web sessions — refresh token rotation with theft detection
model WebSession {
  id           String   @id @default(cuid())
  userId       BigInt
  // SHA-256 hash of the actual refresh token (token itself never stored)
  tokenHash    String   @unique
  family       String   // random ID per login — if old token reused, entire family revoked
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?
  ipAddress    String?
  userAgent    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([family])
}

model Note {
  id        Int      @id @default(autoincrement())
  userId    BigInt
  date      String
  text      String
  tags      String   @default("")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Pair {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  userId1   BigInt
  userId2   BigInt?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  user1     User     @relation("PairUser1", fields: [userId1], references: [id], onDelete: Cascade)
  user2     User?    @relation("PairUser2", fields: [userId2], references: [id], onDelete: SetNull)
}

model UserPractice {
  id        Int      @id @default(autoincrement())
  userId    BigInt
  needId    String
  text      String
  createdAt DateTime @default(now())

  @@index([userId, needId])
}

model PracticePlan {
  id              Int       @id @default(autoincrement())
  userId          BigInt
  needId          String
  practiceText    String
  scheduledDate   String    // YYYY-MM-DD — дата когда планируем выполнить
  reminderUtcHour Int?      // null = без напоминания
  done            Boolean?  // null = не ответил, true/false = результат
  checkedAt       DateTime?
  createdAt       DateTime  @default(now())

  @@index([userId, scheduledDate])
}

model YsqResult {
  userId      BigInt   @id
  answers     Json
  completedAt DateTime @default(now())
}

model YsqResultHistory {
  id          Int      @id @default(autoincrement())
  userId      BigInt
  answers     Json
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, completedAt])
}

model ChildhoodRating {
  id     Int    @id @default(autoincrement())
  userId BigInt
  needId String
  value  Int

  @@unique([userId, needId])
  @@index([userId])
}

model SchemaDiaryEntry {
  id                 Int      @id @default(autoincrement())
  userId             BigInt
  createdAt          DateTime @default(now())
  trigger            String   // Спусковой механизм (что произошло)
  emotions           Json     // {id, intensity}[] — Эмоции
  thoughts           String?  // Мысли (что думаю, предполагаю, чего боюсь)
  bodyFeelings       String?  // Физические проявления (что с телом)
  actualBehavior     String?  // Фактическое поведение (что делаю)
  schemaIds          Json     // string[] — Схемы
  schemaOrigin       String?  // Откуда эта схема
  healthyView        String?  // Здоровый взгляд (что на самом деле происходит)
  realProblems       String?  // Реальные проблемы
  excessiveReactions String?  // Чрезмерные реакции (где переоценил/а)
  healthyBehavior    String?  // Здоровое поведение (что могу сделать)

  @@index([userId, createdAt])
}

model ModeDiaryEntry {
  id                Int      @id @default(autoincrement())
  userId            BigInt
  createdAt         DateTime @default(now())
  modeId            String   // Режим (кто включился)
  situation         String   // Ситуация (что произошло)
  thoughts          String?  // Мысли
  feelings          String?  // Чувства
  bodyFeelings      String?  // Тело (что ощутили)
  actions           String?  // Действия (что конкретно делали)
  actualNeed        String?  // Что на самом деле было нужно
  childhoodMemories String?  // Детские воспоминания связанные с ситуацией

  @@index([userId, createdAt])
}

model GratitudeDiaryEntry {
  id        Int      @id @default(autoincrement())
  userId    BigInt
  date      String
  items     Json     // string[]
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
}

model AppActivity {
  id        Int      @id @default(autoincrement())
  userId    BigInt
  date      String   // YYYY-MM-DD in user's timezone

  @@unique([userId, date])
  @@index([userId])
}

model TherapyRelation {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  therapistId BigInt
  clientId    BigInt?
  status      String   @default("pending") // "pending" | "active"
  clientAlias       String?  // therapist's custom name for client
  virtualClientName String?  // if set: offline/virtual client (no Telegram account)
  therapyStartDate  String?  // YYYY-MM-DD, editable by therapist
  nextSession       String?  // YYYY-MM-DD, next scheduled session
  meetingDays       Json     @default("[]")  // number[] weekdays 0=Sun..6=Sat
  createdAt   DateTime @default(now())

  therapist   User  @relation("TherapistOf", fields: [therapistId], references: [id], onDelete: Cascade)
  client      User? @relation("ClientOf",    fields: [clientId],    references: [id], onDelete: SetNull)

  @@index([therapistId, status])
  @@index([clientId, status])
}

model UserTask {
  id          Int       @id @default(autoincrement())
  userId      BigInt
  assignedBy  BigInt?   // null = self, therapistId = from therapist
  type        String    // 'custom' | 'diary_streak' | 'tracker_streak' | 'schema_diary' | 'mode_diary'
  text        String
  targetDays  Int?      // for streak types
  needId      String?
  dueDate     String?   // YYYY-MM-DD
  done        Boolean?  // null = in progress
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, done, createdAt])
  @@index([userId, done, type])
}

model TherapistNote {
  id          Int      @id @default(autoincrement())
  therapistId BigInt
  clientId    BigInt
  date        String   // YYYY-MM-DD
  text        String
  createdAt   DateTime @default(now())

  @@index([therapistId, clientId, createdAt])
}

model ClientConceptualization {
  id              Int      @id @default(autoincrement())
  therapistId     BigInt
  clientId        BigInt
  schemaIds       Json     @default("[]")  // string[]
  modeIds         Json     @default("[]")  // string[]
  earlyExperience String?  // Ранний дисфункциональный опыт
  unmetNeeds      String?  // Неудовлетворённые базовые потребности
  triggers        String?  // Схемные триггеры
  copingStyles    String?  // Стили совладания
  goals           String?  // Цели схема-терапии
  currentProblems String?  // Текущие проблемы и симптомы
  modeTransitions String?  // Переключение режимов
  modeMapNodes    Json     @default("[]")  // ModeMapNode[] — encrypted JSON
  modeMapEdges    Json     @default("[]")  // ModeMapEdge[] — encrypted JSON
  history         Json     @default("[]")  // ConceptSnapshot[]
  updatedAt       DateTime @updatedAt

  @@unique([therapistId, clientId])
}

// Therapist's personal custom modes — shown in palette across all clients.
model TherapistCustomMode {
  id          Int      @id @default(autoincrement())
  therapistId BigInt
  name        String
  emoji       String   @default("⬡")
  nodeType    String   @default("custom")  // trigger|child|critic|coping|healthy|custom
  createdAt   DateTime @default(now())

  @@index([therapistId, createdAt])
}

// Named mode maps — multiple per client, each with own title and canvas state.
// nodes/edges stored as encrypted JSON (same pattern as modeMapNodes above).
model ModeMap {
  id          Int      @id @default(autoincrement())
  therapistId BigInt
  clientId    BigInt
  title       String   @default("Карта режимов")
  kind        String   @default("problem")  // 'personality' | 'problem'
  nodes       Json     @default("[]")
  edges       Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([therapistId, clientId, createdAt])
}

model UserSchemaNote {
  id          Int      @id @default(autoincrement())
  userId      BigInt
  schemaId    String
  triggers    String   @default("")
  feelings    String   @default("")
  thoughts    String   @default("")
  origins     String   @default("")
  reality     String   @default("")
  healthyView String   @default("")
  behavior    String   @default("")
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, schemaId])
}

model UserModeNote {
  id        Int      @id @default(autoincrement())
  userId    BigInt
  modeId    String
  triggers  String   @default("")
  feelings  String   @default("")
  thoughts  String   @default("")
  needs     String   @default("")
  behavior  String   @default("")
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, modeId])
}

model UserBeliefCheck {
  id              Int      @id @default(autoincrement())
  userId          BigInt
  belief          String
  evidenceFor     String
  evidenceAgainst String
  reframe         String?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UserLetter {
  id        Int      @id @default(autoincrement())
  userId    BigInt
  text      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UserSafePlace {
  userId      BigInt   @id
  description String
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserFlashcard {
  id         Int      @id @default(autoincrement())
  userId     BigInt
  modeId     String
  needId     String
  reflection String?
  action     String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ScheduledNotification {
  id          Int       @id @default(autoincrement())
  userId      BigInt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sendAt      DateTime  // UTC, рассчитано заранее
  type        String    // reminder | summary | onboarding_1 | onboarding_3 | onboarding_7 | streak_7 | streak_14 | streak_30 | lapsing_2 | lapsing_4 | dormant_7 | reengagement_30 | weekly
  payload     Json?
  sentAt      DateTime?
  cancelledAt DateTime?

  @@index([sendAt, sentAt, cancelledAt])
  @@index([userId, type, sentAt])
}

// ── Booking system ───────────────────────────────────────────────────────────

// Therapist's recurring availability rules (e.g. Mon 10:00–19:00, 50 min sessions)
model AvailabilityRule {
  id              Int      @id @default(autoincrement())
  dayOfWeek       Int      // 0=Sun … 6=Sat (JS convention)
  startHour       Int      // local hour, e.g. 10
  startMinute     Int      @default(0)
  endHour         Int      // local hour, e.g. 19
  endMinute       Int      @default(0)
  sessionDuration Int      @default(50)  // minutes
  bufferMin       Int      @default(10)  // gap between sessions
  timezone        String   @default("Europe/Moscow")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
}

enum BookingStatus {
  HELD        // slot reserved, not yet confirmed (hold expires in 15 min)
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum SessionType {
  INTRO_15    // free intro call
  SESSION_50  // full session
}

// One booked (or pending) session. PII fields are AES-256-GCM encrypted.
model Booking {
  id              Int           @id @default(autoincrement())
  startsAt        DateTime      // UTC
  durationMin     Int
  type            SessionType   @default(SESSION_50)
  status          BookingStatus @default(HELD)
  heldUntil       DateTime?     // non-null while status=HELD
  // PII — stored encrypted
  clientName      String
  clientContact   String        // phone or telegram @handle
  message         String?
  clientTelegramId BigInt?      // if client came from Telegram
  cancelToken     String        @unique  // random UUID for self-cancel link
  meetingUrl      String?       // Zoom/Телемост link, set after confirmation
  // CalDAV sync
  calDavUid       String?       @unique  // iCloud event UID
  // Legal: when the client accepted the public offer (consent checkbox) — proof
  // of the basis on which payment is taken. Not encrypted (a timestamp only).
  acceptedOfferAt  DateTime?
  // Reminders
  reminder24SentAt DateTime?
  reminder2SentAt  DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([startsAt, status])
  @@index([heldUntil, status])
}

// Persistent per-client video room. A returning client (same contact) reuses
// the same Zoom meeting link across all their sessions. clientKey is a SHA-256
// hash of the normalised contact — pseudonymised, not reversible.
model ClientMeeting {
  clientKey     String   @id          // sha256(normalised contact)
  meetingUrl    String                // join_url reused for all sessions
  zoomMeetingId String?               // Zoom meeting id (for future updates/deletes)
  createdAt     DateTime @default(now())
}

// Editable key/value settings for the booking module (e.g. session prices),
// so the therapist can change them in the admin panel without code/env edits.
model BookingSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Voluntary donation (app / game), paid via Robokassa. email/comment encrypted.
model Donation {
  id        Int       @id @default(autoincrement())
  amount    Int                          // rubles
  status    String    @default("pending") // pending | paid
  source    String    @default("app")     // app | game
  email     String?
  comment   String?
  createdAt DateTime  @default(now())
  paidAt    DateTime?

  @@index([status, createdAt])
}

// Recurring subscription (support / membership), billed via Robokassa recurring.
// Currently unlocks nothing ("без ограничений") — it's recurring support of the
// project. email is encrypted. Managed by cancelToken (web) or telegramId (bot).
model Subscription {
  id             Int      @id @default(autoincrement())
  status         String   @default("pending") // pending | active | cancelled | past_due
  period         String                        // "month" | "year"
  amount         Int                           // rubles per period
  email          String?                       // encrypted
  telegramId     BigInt?                       // if subscribed from Telegram — for management
  firstInvId     Int?                          // InvId of the establishing charge (PreviousInvoiceID source)
  acceptedOfferAt DateTime?                    // when the client consented to recurring auto-charges
  nextChargeAt   DateTime?                     // when the next recurring charge is due
  lastChargeAt   DateTime?
  failedAttempts Int      @default(0)
  cancelToken    String   @unique              // random UUID for the management/cancel link
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  charges        SubscriptionCharge[]

  @@index([status, nextChargeAt])
}

// One Robokassa payment in a subscription's lifecycle. InvId = base + charge.id,
// so the shared Result webhook can map a payment back to its subscription.
model SubscriptionCharge {
  id             Int          @id @default(autoincrement())
  subscriptionId Int
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amount         Int
  status         String       @default("pending") // pending | paid | failed
  isFirst        Boolean      @default(false)      // the establishing (CIT) payment
  paidAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([subscriptionId])
  @@index([status])
}

// ── Blog articles ────────────────────────────────────────────────────────────

// Site articles (schemehappens.ru/articles), managed from the admin panel.
// Global content, not user-owned data — not part of the account-deletion checklist.
model Article {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  description String
  content     String
  date        DateTime
  readMin     Int
  heroImage   String?  // optional hero image: data URI (uploaded) or path
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
