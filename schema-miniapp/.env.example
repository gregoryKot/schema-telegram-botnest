# Мини-апп собирается ЛОКАЛЬНО (его dist коммитится в git, а не строится в Docker),
# поэтому эти переменные читаются из .env при `npm run build --prefix schema-miniapp`.
# Скопируй в .env перед сборкой.

# API backend URL (пусто — если используется прокси Vite локально)
VITE_API_URL=

# Username Telegram-бота без @ (напр. SchemaLabBot).
# Переезд на новый бот = поменять здесь, пересобрать мини-апп, закоммитить dist.
VITE_BOT_USERNAME=SchemaLabBot

# Короткое имя мини-аппа в deep-link t.me/<bot>/<app> (по умолчанию diary).
# Обычно менять не нужно.
VITE_MINIAPP_APP_NAME=diary
