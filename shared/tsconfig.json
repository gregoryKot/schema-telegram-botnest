{
  // Нужен typed-линту (projectService ищет ближайший tsconfig к файлу) и
  // редакторам. Сборку делают vite обоих фронтендов — сюда только настройки
  // проверки, совместимые с webapp/schema-miniapp.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["src"]
}
